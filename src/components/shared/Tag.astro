---
interface Props {
  href?: string | undefined;
  variant?: "default" | "structural" | "neutral";
  size?: "sm" | "md";
}
const { href, variant = "default", size = "sm" } = Astro.props;

const baseStyle = `
  display: inline-flex;
  align-items: center;
  gap: var(--space-xxs);
  font-family: var(--font-mono);
  text-decoration: none;
  border-radius: var(--radius-sm);
  font-weight: var(--weight-medium);
  letter-spacing: 0;
  transition: all var(--transition-fast);
`;

const sizeStyle =
  size === "sm"
    ? "padding: 2px 6px; font-size: var(--text-caption);"
    : "padding: 4px 8px; font-size: var(--text-body-sm);";

const variantStyle = {
  default:
    "background-color: var(--color-canvas-soft-2); color: var(--color-text-body); border: 1px solid var(--color-hairline);",
  structural:
    "background-color: var(--color-link-bg-soft); color: var(--color-link-deep); border: 1px solid transparent;",
  neutral:
    "background-color: transparent; color: var(--color-text-mute); border: 1px solid var(--color-hairline);",
}[variant];

const fullStyle = `${baseStyle} ${sizeStyle} ${variantStyle}`;
const Tag = href ? "a" : "span";
---

<Tag href={href} style={fullStyle}>
  <slot />
</Tag>
