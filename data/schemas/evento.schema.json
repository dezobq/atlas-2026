{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "evento",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "titulo": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "debate",
        "entrevista",
        "comicio",
        "post_rede_social",
        "sabatina",
        "declaracao_oficial"
      ]
    },
    "local": {
      "type": "object",
      "properties": {
        "fisico": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "digital": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "fisico",
        "digital"
      ],
      "additionalProperties": false
    },
    "duracao_minutos": {
      "anyOf": [
        {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "fonte_primaria_url": {
      "type": "string",
      "format": "uri"
    },
    "fonte_primaria_tipo": {
      "type": "string",
      "enum": [
        "youtube_oficial",
        "tse",
        "camara",
        "senado",
        "diario_oficial",
        "midia_consolidada",
        "rede_social_oficial"
      ]
    },
    "archive_url": {
      "type": "string",
      "format": "uri"
    },
    "candidatos_envolvidos": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "candidato_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "candidato_id"
        ],
        "additionalProperties": false
      }
    },
    "descricao": {
      "type": "string",
      "minLength": 10
    },
    "criado_em": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "atualizado_em": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    }
  },
  "required": [
    "id",
    "titulo",
    "data",
    "tipo",
    "local",
    "duracao_minutos",
    "fonte_primaria_url",
    "fonte_primaria_tipo",
    "archive_url",
    "candidatos_envolvidos",
    "descricao",
    "criado_em",
    "atualizado_em"
  ],
  "additionalProperties": false
}
