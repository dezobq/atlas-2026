{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "candidato",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "nome": {
      "type": "string",
      "minLength": 1
    },
    "foto_url": {
      "type": "string",
      "format": "uri"
    },
    "partido": {
      "type": "string",
      "minLength": 1
    },
    "biografia_minima": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "contas_oficiais": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "plataforma": {
            "type": "string",
            "enum": [
              "youtube",
              "x",
              "instagram",
              "facebook",
              "tiktok"
            ]
          },
          "handle": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "verificada": {
            "type": "boolean"
          }
        },
        "required": [
          "plataforma",
          "handle",
          "url",
          "verificada"
        ],
        "additionalProperties": false
      }
    },
    "criado_em": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "atualizado_em": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    }
  },
  "required": [
    "id",
    "slug",
    "nome",
    "partido",
    "biografia_minima",
    "contas_oficiais",
    "criado_em",
    "atualizado_em"
  ],
  "additionalProperties": false
}
