*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf
*.env text eol=lf
*.gitattributes text eol=lf
